<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="60" height="60" />
    <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="Nombre del hechizo" /></h1>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="datos">Datos</a>
    <a class="item" data-tab="componentes">Componentes</a>
    <a class="item" data-tab="preparacion">Preparación</a>
    <a class="item" data-tab="descripcion">Descripción</a>
  </nav>

  <section class="sheet-body">
    {{!-- ── Pestaña: Datos ── --}}
    <div class="tab" data-group="primary" data-tab="datos">

      <div class="form-group">
        <label>Tipo</label>
        <select name="system.tipo">
          {{#select system.tipo}}
          <option value="conjuro">Conjuro</option>
          <option value="milagro">Milagro</option>
          {{/select}}
        </select>
      </div>

      <div class="form-group">
        <label>{{#ifEquals system.tipo "milagro"}}Ordo{{else}}Vis{{/ifEquals}} (1-7)</label>
        <input type="number" name="system.vis" value="{{system.vis}}" min="1" max="7" data-dtype="Number" />
      </div>

      <div class="form-group">
        <label>Ceremonia</label>
        <select name="system.forma">
          {{#select system.forma}}
          <option value="invocacion">Invocación</option>
          <option value="maleficio">Maleficio</option>
          <option value="pocion">Poción</option>
          <option value="talisman">Talismán</option>
          <option value="unguento">Ungüento</option>
          {{/select}}
        </select>
      </div>

      <div class="form-group">
        <label>Naturaleza</label>
        <select name="system.naturaleza">
          {{#select system.naturaleza}}
          <option value="blanca">Blanca</option>
          <option value="negra">Negra</option>
          {{/select}}
        </select>
      </div>

      <div class="form-group">
        <label>Origen</label>
        <select name="system.origen">
          {{#select system.origen}}
          <option value="popular">Popular</option>
          <option value="alquimico">Alquímico</option>
          <option value="infernal">Infernal</option>
          <option value="prohibido">Prohibido</option>
          <option value="fe">Fe (Milagro)</option>
          {{/select}}
        </select>
      </div>

      <div class="form-group">
        <label>Nombre Latín</label>
        <input type="text" name="system.nombreLatin" value="{{system.nombreLatin}}" placeholder="Nombre canónico en latín" />
      </div>

      <div class="form-group">
        <label>Coste PC</label>
        <input type="number" name="system.costePC" value="{{system.costePC}}" data-dtype="Number" />
      </div>

      <div class="form-group">
        <label>Expiración</label>
        <input type="text" name="system.expiracion" value="{{system.expiracion}}" placeholder="ej: 1 luna, permanente…" />
      </div>

      <div class="form-group">
        <label>Duración</label>
        <input type="text" name="system.duracion" value="{{system.duracion}}" placeholder="ej: 1 hora, instantáneo…" />
      </div>

      <div class="form-group">
        <label>Alcance</label>
        <input type="text" name="system.alcance" value="{{system.alcance}}" />
      </div>

      <div class="form-group">
        <label>Resistible</label>
        <input type="checkbox" name="system.resistible" {{checked system.resistible}} />
      </div>

    </div>

    {{!-- ── Pestaña: Componentes ── --}}
    <div class="tab" data-group="primary" data-tab="componentes">

      {{!-- Componentes requeridos (del compendio, sólo lectura) --}}
      {{#if system.componentesNombres.length}}
      <div class="comp-requeridos">
        <span class="comp-requeridos-label">{{localize "AQUELARRE.Hechizo.componentesRequeridos"}}</span>
        <div class="comp-requeridos-tags">
          {{#each system.componentesNombres as |nombre|}}
          <span class="comp-req-tag">{{nombre}}</span>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{#if componentesData.length}}
      <ul class="items-list hechizo-comp-list">
        <li class="items-header flexrow">
          <span class="item-name">Componente</span>
          <span class="item-detail">Procedencia</span>
          <span class="item-detail">Tipo</span>
          <span class="item-detail">Naturaleza</span>
          <span class="item-controls"></span>
        </li>
        {{#each componentesData as |comp|}}
        <li class="item flexrow" data-comp-id="{{comp._id}}">
          <span class="item-name">{{comp.name}}</span>
          <span class="item-detail">{{comp.system.procedencia}}</span>
          <span class="item-detail">{{comp.system.tipoComponente}}</span>
          <span class="item-detail">{{comp.system.naturaleza}}</span>
          <span class="item-controls">
            {{#if ../editable}}
            <a class="hechizo-remove-comp" data-comp-id="{{comp._id}}" title="Quitar componente">
              <i class="fas fa-unlink"></i>
            </a>
            {{/if}}
          </span>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="hint">Sin componentes asignados. Añade componentes al personaje y asígnalos desde la pestaña de Magia.</p>
      {{/if}}

      {{#if editable}}
      {{#if actorComponentes.length}}
      <div class="form-group" style="margin-top:8px">
        <label>Añadir</label>
        <select id="hechizo-add-comp-select">
          <option value="">— seleccionar componente —</option>
          {{#each actorComponentes as |c|}}
          <option value="{{c._id}}">{{c.name}}</option>
          {{/each}}
        </select>
        <a class="hechizo-add-comp-btn" title="Asignar componente seleccionado">
          <i class="fas fa-plus-circle"></i>
        </a>
      </div>
      {{else}}
      <p class="hint" style="margin-top:8px">El personaje no tiene componentes en su inventario.</p>
      {{/if}}
      {{/if}}
    </div>

    {{!-- ── Pestaña: Preparación ── --}}
    <div class="tab" data-group="primary" data-tab="preparacion">
      <div class="editor-container">
        {{editor system.preparacion target="system.preparacion" button=true editable=editable}}
      </div>
    </div>

    {{!-- ── Pestaña: Descripción ── --}}
    <div class="tab" data-group="primary" data-tab="descripcion">
      {{> "systems/akers_aquelarre/templates/item/parts/item-descripcion.hbs"}}
    </div>
  </section>
</form>
